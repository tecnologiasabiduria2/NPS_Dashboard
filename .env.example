NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Acepta tanto las llaves legacy (eyJ...) como las nuevas (sb_publishable_ / sb_secret_)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

NEXT_PUBLIC_WORKER_URL=https://phantom-media.tecnologia-sabiduria.workers.dev

# GHL v2 — Private Integration Token (PIT) y Location ID
GHL_API_KEY=eyJ...
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Sync inverso → GHL (Bloque 4). Secreto que protege /api/cron/sync-ghl.
# El crontab del VPS hace: curl -H "x-cron-secret: $CRON_SECRET" .../api/cron/sync-ghl
CRON_SECRET=

# Paywall (Bloque 5c). CTA "Renovar acceso" en /access-expired cuando un cliente
# inactivo intenta entrar a una sesión. Funnel de GHL / WhatsApp / checkout.
# Si queda vacío, el paywall muestra solo el mensaje de contacto (sin botón).
NEXT_PUBLIC_RENEW_URL=
